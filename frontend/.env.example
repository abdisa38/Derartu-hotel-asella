# Environment Variables (Optional for future use)
# Copy this file to .env for local development

# API URL (when backend is ready)
# VITE_API_URL=https://api.derartuhotel.com

# Google Maps API Key (for map integration)
# VITE_GOOGLE_MAPS_KEY=your_api_key_here

# Analytics
# VITE_ANALYTICS_ID=your_analytics_id
